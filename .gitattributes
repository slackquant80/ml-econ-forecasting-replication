# Keep repository text files stable across Windows and Linux checkouts.
* text=auto eol=lf

# Binary artifacts must never receive end-of-line conversion.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.gz binary
*.bz2 binary
*.xz binary
*.7z binary
*.rds binary
*.RData binary
*.rda binary
